REPO_PATH='/path/to/your/escargot/clone'
REMOTE_NAME='origin'

# ============================================
# LangSmith Tracing (https://smith.langchain.com)
# ============================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY='your_langsmith_api_key_here'
LANGCHAIN_PROJECT='escargot-review-bot'

# Number of parallel workers for chunk/hunk concurrency
REVIEW_PARALLEL_WORKERS=3
REVIEW_PARALLEL_PASSES=true

# Ollama keep-alive: Keep models loaded long enough during parallel execution
OLLAMA_KEEP_ALIVE=30m

# Specify local models to use for each pass
OLLAMA_MODEL_DEFECT='model-name'
OLLAMA_MODEL_REFACTOR='model-name'
OLLAMA_MODEL_COMPILER='model-name'
OLLAMA_MODEL_STYLE='model-name'

# LLM parameters
OLLAMA_TEMPERATURE=0.1
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_BATCH=256
OLLAMA_REPEAT_PENALTY=1.1
CONFIDENCE_THRESHOLD=0.8

# Timeout / Retry settings
OLLAMA_TIMEOUT_SECONDS=1800
OLLAMA_MAX_RETRIES=2

# Delay (seconds) to mitigate rate limits during parallel requests
INTER_REQUEST_DELAY_SECONDS=0
